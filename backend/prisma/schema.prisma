datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  permissions String[] // Array of strings representing permissions
  admins      Admin[]
  createdAt   DateTime @default(now())
}

model Admin {
  id           String        @id @default(uuid())
  username     String        @unique
  passwordHash String
  roleId       String
  role         Role          @relation(fields: [roleId], references: [id])
  inquiryNotes InquiryNote[]
  activityLogs ActivityLog[]
  createdAt    DateTime      @default(now())
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  slug      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
}

model Product {
  id           String         @id @default(uuid())
  name         String
  description  String
  price        Float
  availability Boolean        @default(true)
  categoryId   String
  category     Category       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  images       ProductImage[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model ProductImage {
  id        String  @id @default(uuid())
  url       String
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Service {
  id          String        @id @default(uuid())
  name        String        @unique
  icon        String        // Lucide icon identifier
  description String
  category    String        // CCTV, Networking, Computer, etc.
  isCore      Boolean       @default(false)
  galleryItems Gallery[]
  inquiries   Inquiry[]
  createdAt   DateTime      @default(now())
}

model Gallery {
  id             String         @id @default(uuid())
  title          String
  description    String
  location       String
  serviceId      String
  service        Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  images         GalleryImage[]
  beforeImageUrl String?
  afterImageUrl  String?
  featured       Boolean        @default(false)
  order          Int            @default(0)
  date           DateTime       @default(now())
  createdAt      DateTime       @default(now())
}

model GalleryImage {
  id        String  @id @default(uuid())
  url       String
  galleryId String
  gallery   Gallery @relation(fields: [galleryId], references: [id], onDelete: Cascade)
}

model Inquiry {
  id           String              @id @default(uuid())
  customerName String
  mobileNumber String
  email        String?
  serviceId    String
  service      Service             @relation(fields: [serviceId], references: [id])
  message      String
  status       String              @default("Unread") // Unread, In Progress, Completed, Closed
  attachments  InquiryAttachment[]
  notes        InquiryNote[]
  createdAt    DateTime            @default(now())
}

model InquiryAttachment {
  id        String  @id @default(uuid())
  url       String
  name      String
  inquiryId String
  inquiry   Inquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
}

model InquiryNote {
  id        String   @id @default(uuid())
  text      String
  inquiryId String
  inquiry   Inquiry  @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  adminId   String
  admin     Admin    @relation(fields: [adminId], references: [id])
  createdAt DateTime @default(now())
}

model Brand {
  id        String   @id @default(uuid())
  name      String   @unique
  logoUrl   String
  createdAt DateTime @default(now())
}

model Testimonial {
  id           String   @id @default(uuid())
  customerName String
  role         String?
  content      String
  rating       Int      @default(5)
  avatarUrl    String?
  createdAt    DateTime @default(now())
}

model CmsSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActivityLog {
  id        String   @id @default(uuid())
  action    String
  ipAddress String?
  userAgent String?
  adminId   String
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
