datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum InquiryStatus {
  UNREAD
  IN_PROGRESS
  COMPLETED
  CLOSED
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  permissions String[]
  admins      Admin[]
  createdAt   DateTime @default(now())
}

model Admin {
  id                   String        @id @default(uuid())
  username             String        @unique
  passwordHash         String
  roleId               String
  role                 Role          @relation(fields: [roleId], references: [id])
  inquiryNotes         InquiryNote[]
  activityLogs         ActivityLog[]
  loginAttempts        Int           @default(0)
  lockoutUntil         DateTime?
  passwordResetToken   String?       @unique
  passwordResetExpires DateTime?
  createdAt            DateTime      @default(now())
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  slug      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
}

model Brand {
  id        String    @id @default(uuid())
  name      String    @unique
  logoUrl   String
  products  Product[]
  createdAt DateTime  @default(now())
}

model Product {
  id              String         @id @default(uuid())
  name            String
  slug            String         @unique
  description     String
  price           Float?
  showPrice       Boolean        @default(false)
  contactForPrice Boolean        @default(true)
  availability    Boolean        @default(true) // true = In Stock, false = Out of Stock
  sku             String?        @unique
  modelNumber     String?
  specifications  String?
  warranty        String?
  featured        Boolean        @default(false)
  displayOrder    Int            @default(0)
  seoTitle        String?
  seoDescription  String?
  metaImage       String?
  keywords        String[]
  categoryId      String
  category        Category       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  brandId         String?
  brand           Brand?         @relation(fields: [brandId], references: [id], onDelete: SetNull)
  images          ProductImage[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model ProductImage {
  id        String  @id @default(uuid())
  url       String
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Service {
  id            String         @id @default(uuid())
  name          String         @unique
  description   String
  icon          String
  bannerUrl     String?
  displayOrder  Int            @default(0)
  featured      Boolean        @default(false)
  active        Boolean        @default(true)
  buttonText    String?        @default("Request Service")
  buttonLink    String?
  images        ServiceImage[]
  galleryItems  Gallery[]
  inquiries     Inquiry[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model ServiceImage {
  id        String  @id @default(uuid())
  url       String
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model Gallery {
  id             String         @id @default(uuid())
  title          String
  slug           String         @unique
  description    String
  location       String
  clientName     String?
  duration       String?
  technologies   String[]
  serviceId      String
  service        Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  images         GalleryImage[]
  beforeImageUrl String?
  afterImageUrl  String?
  featured       Boolean        @default(false)
  order          Int            @default(0)
  completionDate DateTime       @default(now())
  createdAt      DateTime       @default(now())
}

model GalleryImage {
  id        String  @id @default(uuid())
  url       String
  galleryId String
  gallery   Gallery @relation(fields: [galleryId], references: [id], onDelete: Cascade)
}

model Inquiry {
  id           String              @id @default(uuid())
  customerName String
  mobileNumber String
  email        String?
  serviceId    String
  service      Service             @relation(fields: [serviceId], references: [id])
  message      String
  status       InquiryStatus       @default(UNREAD)
  attachments  InquiryAttachment[]
  notes        InquiryNote[]
  createdAt    DateTime            @default(now())
}

model InquiryAttachment {
  id        String  @id @default(uuid())
  url       String
  name      String  // "laptopImage", "cctvImage", "computerImage", etc.
  inquiryId String
  inquiry   Inquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
}

model InquiryNote {
  id        String   @id @default(uuid())
  text      String
  inquiryId String
  inquiry   Inquiry  @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  adminId   String
  admin     Admin    @relation(fields: [adminId], references: [id])
  createdAt DateTime @default(now())
}

model Testimonial {
  id                String   @id @default(uuid())
  customerName      String
  city              String?
  content           String   @db.Text
  rating            Int      @default(5)
  avatarUrl         String?
  verified          Boolean  @default(false)
  serviceUsed       String?
  reviewDate        DateTime @default(now())
  replyFromBusiness String?  @db.Text
  approved          Boolean  @default(false)
  featured          Boolean  @default(false)
  createdAt         DateTime @default(now())
}

model CmsSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String   @db.Text
  type        String   @default("text") // text, image, json, number
  group       String   @default("General") // Hero, Contact, Footer, Statistics
  description String?
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MediaAsset {
  id        String   @id @default(uuid())
  filename  String
  url       String
  mimeType  String
  size      Int
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(uuid())
  action    String
  ipAddress String?
  userAgent String?
  adminId   String
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
